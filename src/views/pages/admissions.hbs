<!-- Page Header Banner -->
<section class="page-header position-relative overflow-hidden py-5 bg-navy text-white d-flex align-items-center" style="min-height: 220px;">
    <div class="container position-relative z-2 pt-4">
        <div class="row">
            <div class="col-12" data-aos="fade-right">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2 text-white-50">
                        <li class="breadcrumb-item"><a href="/" class="text-white-50 text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item active text-white" aria-current="page">Admissions</li>
                    </ol>
                </nav>
                <h1 class="display-5 fw-extrabold m-0" style="font-family: 'Plus Jakarta Sans', sans-serif;">Admissions 2026-27</h1>
                <p class="text-white-50 small m-0 mt-1">Enroll at AGMRCET and join our league of engineering leaders.</p>
            </div>
        </div>
    </div>
    <div class="page-header-glow"></div>
</section>

<!-- Admissions Process Steps -->
<section class="py-5 bg-light-slate">
    <div class="container">
        <div class="text-center mb-5 max-w-600 mx-auto" data-aos="fade-up">
            <span class="text-primary text-uppercase tracking-wider fw-bold small">How to Apply</span>
            <h2 class="fw-bold text-navy mt-1" style="font-family: 'Plus Jakarta Sans', sans-serif;">Admission Process</h2>
            <p class="text-muted">A step-by-step walkthrough to secure your enrollment at AGMRCET.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="glassmorphism p-4 rounded-4 shadow-sm border border-white-50 h-100 text-center">
                    <div class="step-badge bg-primary text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-weight: 800;">1</div>
                    <h5 class="fw-bold text-navy mb-2">Inquiry Submission</h5>
                    <p class="text-muted small m-0">Fill out our online inquiry form with basic details, or visit the college admin office.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="glassmorphism p-4 rounded-4 shadow-sm border border-white-50 h-100 text-center">
                    <div class="step-badge bg-secondary text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-weight: 800;">2</div>
                    <h5 class="fw-bold text-navy mb-2">Counseling & Eligibility</h5>
                    <p class="text-muted small m-0">Our admissions counselors evaluate your grades, KCET / COMEDK marks, and branch choices.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="glassmorphism p-4 rounded-4 shadow-sm border border-white-50 h-100 text-center">
                    <div class="step-badge bg-accent text-dark rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-weight: 800;">3</div>
                    <h5 class="fw-bold text-navy mb-2">Verification</h5>
                    <p class="text-muted small m-0">Submit original marks cards, caste/income certs (if applicable), and identity proofs for VTU enrollment.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="glassmorphism p-4 rounded-4 shadow-sm border border-white-50 h-100 text-center">
                    <div class="step-badge bg-success text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-weight: 800;">4</div>
                    <h5 class="fw-bold text-navy mb-2">Fee Payment</h5>
                    <p class="text-muted small m-0">Fulfill the semester tuition fee payment through portal or bank draft to seal your admission.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Courses Offered & Eligibility Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5 max-w-600 mx-auto" data-aos="fade-up">
            <span class="text-primary text-uppercase tracking-wider fw-bold small">Academics Portfolio</span>
            <h2 class="fw-bold text-navy mt-1" style="font-family: 'Plus Jakarta Sans', sans-serif;">Eligibility & Courses Offered</h2>
            <p class="text-muted">Explore details of UG and PG courses, intakes, and requirements.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Tabs -->
                <ul class="nav nav-pills nav-fill mb-4 p-1 bg-light rounded-3 shadow-sm" id="courseTabs" role="tablist" data-aos="fade-up">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active rounded-2 py-2 fw-semibold" id="ug-tab" data-bs-toggle="pill" data-bs-target="#ug-courses" type="button" role="tab" aria-controls="ug-courses" aria-selected="true">Undergraduate (B.E.)</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link rounded-2 py-2 fw-semibold" id="pg-tab" data-bs-toggle="pill" data-bs-target="#pg-courses" type="button" role="tab" aria-controls="pg-courses" aria-selected="false">Postgraduate (MBA / MCA)</button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="courseTabsContent" data-aos="fade-up">
                    <!-- UG Tab -->
                    <div class="tab-pane fade show active" id="ug-courses" role="tabpanel" aria-labelledby="ug-tab">
                        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
                            <h5 class="fw-bold text-navy mb-3"><i class="bi bi-info-circle-fill text-primary me-2"></i>UG Eligibility Criteria</h5>
                            <p class="text-muted small">
                                Candidates must have passed 10+2 (Pre-University College / Intermediate) with Physics and Mathematics as compulsory subjects, along with Chemistry / Biotechnology / Biology / Computer Science as optional subjects. 
                                <br><strong>Min. Marks:</strong> General Category: 45% aggregate in optional subjects; SC/ST/OBC (Karnataka Candidates): 40%. Must qualify in KCET or COMEDK exam.
                            </p>
                        </div>
                        <div class="table-responsive rounded-3 border overflow-hidden shadow-sm">
                            <table class="table table-hover table-striped align-middle mb-0 text-start small">
                                <thead class="table-navy text-white fw-bold">
                                    <tr>
                                        <th scope="col" class="py-3">Course / Branch</th>
                                        <th scope="col" class="py-3">Duration</th>
                                        <th scope="col" class="py-3 text-center">Annual Intake</th>
                                        <th scope="col" class="py-3">Branch Code</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each depts}}
                                    {{#unless (eq this.id "mba")}}
                                    {{#unless (eq this.id "mca")}}
                                    <tr>
                                        <td class="fw-semibold text-navy py-3">{{this.name}}</td>
                                        <td>{{this.duration}}</td>
                                        <td class="text-center fw-bold">{{this.intake}} Seats</td>
                                        <td><span class="badge bg-light text-dark text-uppercase border">{{this.id}}</span></td>
                                    </tr>
                                    {{/unless}}
                                    {{/unless}}
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- PG Tab -->
                    <div class="tab-pane fade" id="pg-courses" role="tabpanel" aria-labelledby="pg-tab">
                        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
                            <h5 class="fw-bold text-navy mb-3"><i class="bi bi-info-circle-fill text-primary me-2"></i>PG Eligibility Criteria</h5>
                            <p class="text-muted small">
                                <strong>MBA:</strong> Passed Bachelor degree of minimum 3 years duration with minimum 50% marks (45% for SC/ST/OBC Karnataka candidates) in aggregate. Must qualify in PGCET or KMAT.
                                <br><strong>MCA:</strong> Passed BCA / Bachelor Degree in Computer Science Engineering or equivalent Degree. Or passed B.Sc. / B.Com. / B.A. with Mathematics at 10+2 level or at Graduation Level. Minimum 50% aggregate marks (45% for SC/ST/OBC Karnataka candidates).
                            </p>
                        </div>
                        <div class="table-responsive rounded-3 border overflow-hidden shadow-sm">
                            <table class="table table-hover table-striped align-middle mb-0 text-start small">
                                <thead class="table-navy text-white fw-bold">
                                    <tr>
                                        <th scope="col" class="py-3">Course / Branch</th>
                                        <th scope="col" class="py-3">Duration</th>
                                        <th scope="col" class="py-3 text-center">Annual Intake</th>
                                        <th scope="col" class="py-3">Code</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="fw-semibold text-navy py-3">Master of Business Administration (MBA)</td>
                                        <td>2 Years</td>
                                        <td class="text-center fw-bold">60 Seats</td>
                                        <td><span class="badge bg-light text-dark text-uppercase border">mba</span></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-semibold text-navy py-3">Master of Computer Applications (MCA)</td>
                                        <td>2 Years</td>
                                        <td class="text-center fw-bold">60 Seats</td>
                                        <td><span class="badge bg-light text-dark text-uppercase border">mca</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Admissions Inquiry & Download Brochure Section -->
<section id="inquiry-form" class="py-5 bg-light-slate">
    <div class="container">
        <div class="row justify-content-center g-5">
            <!-- Left Panel: Brochure and Counselor contact -->
            <div class="col-lg-4" data-aos="fade-right">
                <div class="glassmorphism p-4 rounded-4 shadow-sm border border-white-50 h-100 d-flex flex-column justify-content-between">
                    <div>
                        <h4 class="fw-bold text-navy mb-3">Download Brochure</h4>
                        <p class="text-muted small mb-4">Get access to the comprehensive admission details, seat splits, placement reports, and hostel details offline.</p>
                        <!-- Simulated Download -->
                        <button id="download-brochure-btn" class="btn btn-outline-primary w-100 py-3 rounded-2 text-uppercase tracking-wider fw-bold small mb-4">
                            <i class="bi bi-file-earmark-pdf-fill me-2"></i>Download Prospectus PDF
                        </button>
                    </div>

                    <div class="border-top pt-4">
                        <h6 class="fw-bold text-navy mb-2">Admission Desk Contacts</h6>
                        <p class="text-muted small mb-0">
                            <i class="bi bi-telephone-fill text-accent me-2"></i>+91 94810 87999<br>
                            <i class="bi bi-telephone-fill text-accent me-2"></i>+91 98802 85666<br>
                            <i class="bi bi-envelope-fill text-accent me-2"></i>admissions@agmrcet.ac.in
                        </p>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Inquiry Form -->
            <div class="col-lg-6" data-aos="fade-left">
                <div class="glassmorphism p-5 rounded-4 shadow-lg border border-white-50 bg-white">
                    <h3 class="fw-bold text-navy mb-2" style="font-family: 'Plus Jakarta Sans', sans-serif;">Online Admission Inquiry</h3>
                    <p class="text-muted small mb-4">Fill out the fields below and our counseling division will get in touch with you shortly.</p>

                    <!-- Alert message box -->
                    <div id="inquiry-alert" class="alert alert-success d-none mb-3" role="alert"></div>

                    <form id="online-inquiry-form">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="inquiry-name" class="form-label small fw-bold text-navy mb-1">Full Name</label>
                                <input type="text" class="form-control shadow-none rounded-2" id="inquiry-name" placeholder="John Doe" required>
                            </div>
                            <div class="col-md-6">
                                <label for="inquiry-email" class="form-label small fw-bold text-navy mb-1">Email Address</label>
                                <input type="email" class="form-control shadow-none rounded-2" id="inquiry-email" placeholder="john@example.com" required>
                            </div>
                            <div class="col-md-6">
                                <label for="inquiry-phone" class="form-label small fw-bold text-navy mb-1">Phone Number</label>
                                <input type="tel" class="form-control shadow-none rounded-2" id="inquiry-phone" placeholder="9876543210" required>
                            </div>
                            <div class="col-md-6">
                                <label for="inquiry-course" class="form-label small fw-bold text-navy mb-1">Select Course</label>
                                <select class="form-select shadow-none rounded-2" id="inquiry-course" required>
                                    <option value="" disabled selected>Choose branch...</option>
                                    <option value="Computer Science (CSE)">B.E. Computer Science & Eng.</option>
                                    <option value="CSE (AI & ML)">B.E. CSE (AI & ML)</option>
                                    <option value="Computer Science & Design (CSD)">B.E. Computer Science & Design</option>
                                    <option value="Electronics & Communication (ECE)">B.E. Electronics & Communication</option>
                                    <option value="Electrical & Electronics (EEE)">B.E. Electrical & Electronics</option>
                                    <option value="Mechanical Engineering (ME)">B.E. Mechanical Engineering</option>
                                    <option value="Civil Engineering (CE)">B.E. Civil Engineering</option>
                                    <option value="MBA">Postgraduate MBA</option>
                                    <option value="MCA">Postgraduate MCA</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label for="inquiry-message" class="form-label small fw-bold text-navy mb-1">Detailed Inquiry Message</label>
                                <textarea class="form-control shadow-none rounded-2" id="inquiry-message" rows="4" placeholder="Briefly specify details about your queries..." required></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" id="inquiry-submit-btn" class="btn btn-primary w-100 py-3 text-uppercase tracking-wider fw-bold small rounded-2">
                                    Submit Inquiry Details <i class="bi bi-chevron-right ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQs Accordion Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5 max-w-600 mx-auto" data-aos="fade-up">
            <span class="text-primary text-uppercase tracking-wider fw-bold small">FAQ Desk</span>
            <h2 class="fw-bold text-navy mt-1" style="font-family: 'Plus Jakarta Sans', sans-serif;">Frequently Asked Questions</h2>
            <p class="text-muted">Find quick resolutions to common queries regarding courses, hostel, and admissions.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8" data-aos="fade-up">
                <div class="accordion" id="admissionsAccordion">
                    <!-- FAQ 1 -->
                    <div class="accordion-item border rounded-3 mb-3 overflow-hidden shadow-sm">
                        <h2 class="accordion-header" id="faq-head-1">
                            <button class="accordion-button fw-bold text-navy" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-1" aria-expanded="true" aria-controls="faq-collapse-1">
                                What is the location of the college campus?
                            </button>
                        </h2>
                        <div id="faq-collapse-1" class="accordion-collapse collapse show" aria-labelledby="faq-head-1" data-bs-parent="#admissionsAccordion">
                            <div class="accordion-body text-muted small">
                                The college campus is located adjacent to the scenic Navagraha Teertha pilgrimage site, NH-4 Road, Varur, which is approximately 18 kilometers from Hubli City, Karnataka. Regular transport and college buses are available from various parts of Hubli and Dharwad.
                            </div>
                        </div>
                    </div>
                    <!-- FAQ 2 -->
                    <div class="accordion-item border rounded-3 mb-3 overflow-hidden shadow-sm">
                        <h2 class="accordion-header" id="faq-head-2">
                            <button class="accordion-button collapsed fw-bold text-navy" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-2" aria-expanded="false" aria-controls="faq-collapse-2">
                                Are separate hostel accommodations available for boys and girls?
                            </button>
                        </h2>
                        <div id="faq-collapse-2" class="accordion-collapse collapse" aria-labelledby="faq-head-2" data-bs-parent="#admissionsAccordion">
                            <div class="accordion-body text-muted small">
                                Yes, AGMRCET provides separate secure hostels for boys and girls on-campus. Features include Wi-Fi connection, hot water access, study halls, hygienic mess food services, and CCTV cameras surveillance with 24/7 security.
                            </div>
                        </div>
                    </div>
                    <!-- FAQ 3 -->
                    <div class="accordion-item border rounded-3 mb-3 overflow-hidden shadow-sm">
                        <h2 class="accordion-header" id="faq-head-3">
                            <button class="accordion-button collapsed fw-bold text-navy" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-3" aria-expanded="false" aria-controls="faq-collapse-3">
                                Does the college offer placement training assistance?
                            </button>
                        </h2>
                        <div id="faq-collapse-3" class="accordion-collapse collapse" aria-labelledby="faq-head-3" data-bs-parent="#admissionsAccordion">
                            <div class="accordion-body text-muted small">
                                Yes, our Training & Placement Cell provides mandatory soft skills development, aptitude reasoning classes, database structures training, and simulated mock interviews to prepare students for campus recruitments beginning from the 3rd year.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
