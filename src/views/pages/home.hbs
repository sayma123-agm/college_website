                        </div>
                        <div class="text-lg-end">
                            <span class="text-muted small d-block">Annual Intake Capacity</span>
                            <span class="fw-bold text-navy fs-4">{{this.intake}} Seats</span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- HOD Profile -->
                        <div class="col-md-6 border-end-md">
                            <h5 class="fw-bold text-navy mb-3"><i class="bi bi-person-workspace text-primary me-2"></i>Department HOD</h5>
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <img src="{{this.hodPhoto}}" 
                                     alt="{{this.hodName}}" 
                                     class="rounded-circle border border-2 border-primary-subtle object-fit-cover shadow-sm" 
                                     style="width: 75px; height: 75px; min-width: 75px;">
                                <div>
                                    <h6 class="fw-bold text-navy m-0" style="font-size: 14px;">{{this.hodName}}</h6>
                                    <span class="text-muted small" style="font-size: 11px;">HOD & Professor</span>
                                    <p class="text-primary-emphasis text-xs m-0 font-semibold" style="font-size: 10px;">Exp: {{this.hodExp}}</p>
                                </div>
                            </div>
