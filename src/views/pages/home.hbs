        </div>

        <div class="row g-4" data-aos="fade-up">
            <!-- Left Column: Department List -->
            <div class="col-lg-4">
                <div class="d-flex flex-lg-column flex-nowrap overflow-x-auto gap-2 pb-2 scrollbar-none border-bottom border-bottom-lg-0" style="-webkit-overflow-scrolling: touch;">
                    {{#each depts}}
                    <button type="button" 
                            class="dept-explorer-btn w-100 text-start btn btn-light border p-3 rounded-3 d-flex align-items-center justify-content-between gap-3 cursor-pointer transition-all {{#if @first}}active bg-primary text-white border-primary shadow-sm{{/if}}"
                            data-dept-id="{{this.id}}"
                            style="white-space: nowrap;">
                        <span class="fw-bold fs-6">{{this.name}} ({{this.shortName}})</span>
                        <i class="bi bi-chevron-right d-none d-lg-block"></i>
                    </button>
                    {{/each}}
                </div>
            </div>

            <!-- Right Column: Interactive details card -->
            <div class="col-lg-8">
                {{#each depts}}
                <div class="dept-details-card glassmorphism p-4 p-md-5 rounded-4 shadow-sm border border-white-50 h-100 {{#if @first}}d-block{{else}}d-none{{/if}}" 
                     id="dept-card-{{this.id}}">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4 border-bottom pb-3">
                        <div>
                            <span class="badge bg-accent text-dark text-uppercase tracking-wider fw-bold px-3 py-1.5 mb-2" style="font-size: 9px;">Established: {{this.established}} | Duration: {{this.duration}}</span>
