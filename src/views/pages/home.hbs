<!-- ERP Smart Ecosystem Login Section -->
<section id="erp-login-section" class="py-12 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4">
        <div class="text-center mb-10 max-w-2xl mx-auto" data-aos="fade-up">
            <span class="text-primary font-bold uppercase tracking-wider text-xs px-3 py-1 bg-blue-50 border border-blue-100 rounded-full">Digital Governance</span>
            <h2 class="text-3xl font-extrabold text-navy mt-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">Smart ERP Ecosystem</h2>
            <p class="text-gray-500 mt-2">Access college records, performance trackers, fee modules, and governance channels instantly via unified role-based portals.</p>
        </div>

        <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl border border-gray-100 p-6 md:p-8" data-aos="fade-up" data-aos-delay="100">
            <!-- Tabs Navigation -->
            <div class="flex flex-wrap justify-between border-b border-gray-200 pb-3 gap-2">
                <button type="button" onclick="switchErpTab('student')" id="tab-student" class="erp-tab-btn flex-1 py-3 px-2 text-center font-bold text-sm tracking-wide border-b-2 border-primary text-primary transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-people-fill text-lg"></i> Student
                </button>
                <button type="button" onclick="switchErpTab('faculty')" id="tab-faculty" class="erp-tab-btn flex-1 py-3 px-2 text-center font-semibold text-gray-500 text-sm tracking-wide border-b-2 border-transparent hover:text-navy transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-person-badge-fill text-lg"></i> Faculty
                </button>
                <button type="button" onclick="switchErpTab('principal')" id="tab-principal" class="erp-tab-btn flex-1 py-3 px-2 text-center font-semibold text-gray-500 text-sm tracking-wide border-b-2 border-transparent hover:text-navy transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-award-fill text-lg"></i> Principal
                </button>
                <button type="button" onclick="switchErpTab('parent')" id="tab-parent" class="erp-tab-btn flex-1 py-3 px-2 text-center font-semibold text-gray-500 text-sm tracking-wide border-b-2 border-transparent hover:text-navy transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-heart-fill text-lg"></i> Parent
                </button>
                <button type="button" onclick="switchErpTab('fee')" id="tab-fee" class="erp-tab-btn flex-1 py-3 px-2 text-center font-semibold text-gray-500 text-sm tracking-wide border-b-2 border-transparent hover:text-navy transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-credit-card-fill text-lg"></i> Fee Section
                </button>
                <button type="button" onclick="switchErpTab('admin')" id="tab-admin" class="erp-tab-btn flex-1 py-3 px-2 text-center font-semibold text-gray-500 text-sm tracking-wide border-b-2 border-transparent hover:text-navy transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="bi bi-gear-fill text-lg"></i> Admin
                </button>
            </div>

            <!-- Login Form Area -->
            <div class="mt-8">
                <form id="erp-login-form" onsubmit="handleErpSubmit(event)" class="space-y-6">
                    <input type="hidden" id="selected-role" name="role" value="student">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Left Panel: Form fields -->
                        <div class="space-y-4">
                            <div>
                                <label id="username-label" class="block text-xs font-bold uppercase tracking-wider text-navy mb-2">Student USN / ID</label>
                                <div class="relative">
                                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400"><i class="bi bi-person-vcard text-lg"></i></span>
                                    <input type="text" id="erp-username" required class="block w-full pl-10 pr-3 py-3 border border-gray-200 rounded-lg text-navy bg-gray-50 focus:bg-white focus:border-primary focus:ring-2 focus:ring-blue-100 transition-all font-medium text-sm shadow-sm" placeholder="e.g. 2AG22CS001">
                                </div>
                                <p id="hint-text" class="text-xs text-gray-400 mt-2 italic">Hint: Try USN "2AG22CS001" to log in instantly</p>
                            </div>
                            
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-wider text-navy mb-2">Secure Passcode</label>
                                <div class="relative">
                                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400"><i class="bi bi-lock text-lg"></i></span>
                                    <input type="password" id="erp-password" required class="block w-full pl-10 pr-3 py-3 border border-gray-200 rounded-lg text-navy bg-gray-50 focus:bg-white focus:border-primary focus:ring-2 focus:ring-blue-100 transition-all font-medium text-sm shadow-sm" placeholder="••••••••">
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between pt-2">
                                <label class="flex items-center text-xs text-gray-500 font-semibold cursor-pointer">
                                    <input type="checkbox" class="mr-2 rounded text-primary focus:ring-0"> Remember Session
                                </label>
                                <a href="#" class="text-xs text-primary font-bold hover:underline">Reset Passcode?</a>
                            </div>

                            <button type="submit" class="w-full bg-primary hover:bg-navy text-white font-bold py-3.5 px-4 rounded-lg tracking-wider text-uppercase text-xs transition-all shadow-md hover:shadow-lg mt-3 flex items-center justify-center gap-2 cursor-pointer border-0">
                                Access ERP Portal <i class="bi bi-arrow-right-short text-lg"></i>
                            </button>
                        </div>
                        
                        <!-- Right Panel: Visual Context -->
                        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-100 rounded-xl p-6 flex flex-col justify-between">
                            <div>
                                <h5 id="info-title" class="font-extrabold text-navy flex items-center gap-2 text-base"><i class="bi bi-patch-check-fill text-primary"></i> Academic Tracker Portal</h5>
                                <p id="info-desc" class="text-xs text-gray-500 mt-2 leading-relaxed">Access real-time attendance percentages, internal assessments results, course syllabi guidelines, VTU end-semester marks, and submit elective preferences dynamically.</p>
                            </div>
                            
                            <!-- Mini Metrics display -->
                            <div class="grid grid-cols-2 gap-4 mt-6">
                                <div class="bg-white border border-gray-100 rounded-lg p-3 shadow-xs">
                                    <span class="block text-gray-400 uppercase font-bold text-[9px] tracking-wider">Avg Latency</span>
                                    <span class="font-extrabold text-navy text-sm">12ms</span>
                                </div>
                                <div class="bg-white border border-gray-100 rounded-lg p-3 shadow-xs">
                                    <span class="block text-gray-400 uppercase font-bold text-[9px] tracking-wider">Status</span>
                                    <span class="font-extrabold text-green-600 text-sm flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500 inline-block animate-ping"></span> Online</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Latest News and Events Section -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5" data-aos="fade-up">
            <div>
                <span class="text-primary text-uppercase tracking-wider fw-bold small">Latest Bulletins</span>
                <h2 class="fw-extrabold text-navy mt-1 m-0" style="font-family: 'Plus Jakarta Sans', sans-serif;">News & Announcements</h2>
            </div>
            <a href="/news" class="btn btn-outline-primary btn-sm px-3 rounded-2 text-uppercase tracking-wider fw-bold">View All News</a>
        </div>

        <div class="row g-4">
            {{#each importantNews}}
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card transition-all hover-translate">
                    <div class="bg-primary text-white p-3 d-flex justify-content-between align-items-center">
                        <span class="badge bg-accent text-dark text-uppercase fw-bold">{{this.category}}</span>
                        <small class="text-white-50"><i class="bi bi-calendar3 me-1"></i>{{this.date}}</small>
                    </div>
                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="fw-bold text-navy mb-2 line-clamp-2">{{this.title}}</h5>
                        <p class="text-muted small flex-grow-1 line-clamp-3">{{this.content}}</p>
                        <a href="/news" class="btn btn-link text-primary fw-semibold p-0 text-start text-decoration-none mt-3">Read more <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>
