<!-- Latest News and Events Section -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5" data-aos="fade-up">
            <div>
                <span class="text-primary text-uppercase tracking-wider fw-bold small">Latest Bulletins</span>
                <h2 class="fw-extrabold text-navy mt-1 m-0" style="font-family: 'Plus Jakarta Sans', sans-serif; color: #0B3D91;">News & Announcements</h2>
            </div>
            <a href="/news" class="btn btn-outline-primary btn-sm px-3 rounded-2 text-uppercase tracking-wider fw-bold">View All News</a>
        </div>

        <div class="row g-4">
            {{#each importantNews}}
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card transition-all hover-translate bg-white p-0">
                    <div class="bg-primary text-white p-3 d-flex justify-content-between align-items-center bg-primary-gradient">
                        <span class="badge bg-accent text-dark text-uppercase fw-bold">{{this.category}}</span>
                        <small class="text-white-50"><i class="bi bi-calendar3 me-1"></i>{{this.date}}</small>
                    </div>
                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="fw-bold text-navy mb-2 line-clamp-2">{{this.title}}</h5>
                        <p class="text-muted small flex-grow-1 line-clamp-3">{{this.content}}</p>
                        <a href="/news" class="btn btn-link text-primary fw-semibold p-0 text-start text-decoration-none mt-3">Read more <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>
