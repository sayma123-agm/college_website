<!-- Virtual 360 Degree Tour Section -->
<section id="virtualtour" class="py-5">
    <div class="container">
        <div class="text-center mb-5 max-w-600 mx-auto" data-aos="fade-up">
            <span class="text-primary text-uppercase tracking-wider fw-bold small">Explore Virtually</span>
            <h2 class="fw-bold text-navy mt-1" style="font-family: 'Plus Jakarta Sans', sans-serif;">360° Virtual Campus Tour</h2>
            <p class="text-muted">Take a simulated interactive tour of our main campus buildings, grounds, and research facilities from home.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10" data-aos="zoom-in">
                <!-- Virtual Tour Iframe Simulation Container -->
                <div class="virtual-tour-box position-relative rounded-4 overflow-hidden shadow-lg border border-light-subtle">
                    <!-- Overlay Start Tour UI -->
                    <div id="virtual-tour-overlay" class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-black-70 text-white text-center p-4 z-2 transition-all">
                        <i class="bi bi-compass display-3 text-accent mb-3 animate-spin"></i>
                        <h4 class="fw-bold">Welcome to the AGMRCET 360° Virtual Tour</h4>
                        <p class="small text-white-50 max-w-400 mb-4">Navigate through hotspots to explore our library, administrative offices, labs, and sports arenas in 360 degrees.</p>
                        <button id="start-tour-btn" class="btn btn-primary px-4 py-2 text-uppercase tracking-wider fw-bold small">
                            Start Virtual Tour
                        </button>
                    </div>
                    <!-- Simulated Panoramics Screen -->
                    <div id="virtual-tour-screen" class="w-100 position-relative bg-dark d-flex align-items-center justify-content-center text-white" style="height: 480px;">
                        <!-- Hotspots will load here in simulated JS -->
                        <img id="pano-image" src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80" alt="Pano View" class="w-100 h-100 object-fit-cover opacity-50 position-absolute top-0 start-0">
                        <div class="pano-content text-center z-1 d-none p-3">
                            <h5 class="fw-bold m-0" id="pano-title">Campus Main Gate Entry</h5>
                            <p class="text-white-50 text-xs mt-1" id="pano-desc">A beautiful view of the entrance gates on NH-4 highway.</p>
                            <!-- Hotspot markers -->
                            <div class="d-flex justify-content-center gap-3 mt-4">
                                <button class="btn btn-sm btn-outline-light rounded-pill px-3 active" onclick="switchPano('gate')">Main Gate</button>
                                <button class="btn btn-sm btn-outline-light rounded-pill px-3" onclick="switchPano('admin')">Admin Block</button>
                                <button class="btn btn-sm btn-outline-light rounded-pill px-3" onclick="switchPano('library')">Central Library</button>
                                <button class="btn btn-sm btn-outline-light rounded-pill px-3" onclick="switchPano('hostel')">Hostel Blocks</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Simple simulated Virtual Tour logic -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const startBtn = document.getElementById('start-tour-btn');
        const overlay = document.getElementById('virtual-tour-overlay');
        const panoContent = document.querySelector('.pano-content');
        const panoImage = document.getElementById('pano-image');

        if (startBtn) {
            startBtn.addEventListener('click', () => {
                overlay.classList.add('opacity-0');
                setTimeout(() => {
                    overlay.classList.add('d-none');
                    panoContent.classList.remove('d-none');
                    panoImage.classList.remove('opacity-50');
                }, 400);
            });
        }
    });

    const panoData = {
        gate: {
            title: 'Campus Main Gate Entry',
            desc: 'A beautiful view of the entrance gates on NH-4 highway.',
            img: 'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80'
        },
        admin: {
            title: 'Administrative Block',
            desc: 'Houses the Principal chamber, reception desk, registrar offices, and boardroom.',
            img: 'https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1200&q=80'
        },
        library: {
            title: 'Central Library Block',
            desc: 'Features spacious reading rooms and our digital resources center.',
            img: 'https://images.unsplash.com/photo-1521587760476-6c12a4b040da?auto=format&fit=crop&w=1200&q=80'
        },
        hostel: {
            title: 'Residential Hostels Grounds',
            desc: 'Spacious grounds where separate student residences are built.',
            img: 'https://images.unsplash.com/photo-1555854877-bab0e564b8d5?auto=format&fit=crop&w=1200&q=80'
        }
    };

    function switchPano(spot) {
        const title = document.getElementById('pano-title');
        const desc = document.getElementById('pano-desc');
        const img = document.getElementById('pano-image');
        
        if (panoData[spot]) {
            img.style.opacity = '0.3';
            setTimeout(() => {
                title.innerText = panoData[spot].title;
                desc.innerText = panoData[spot].desc;
                img.src = panoData[spot].img;
                img.style.opacity = '1';
            }, 300);

            // Update active state of buttons
            const buttons = document.querySelectorAll('#virtual-tour-screen button');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }
    }
</script>
