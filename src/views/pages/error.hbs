<section class="error-section d-flex align-items-center justify-content-center py-5 min-vh-75">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <!-- Glassmorphic Card -->
                <div class="glassmorphism p-5 rounded-4 shadow-lg border border-white-10" data-aos="fade-up">
                    <div class="error-icon-box text-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill display-1 animate-pulse"></i>
                    </div>
                    <h1 class="display-4 fw-extrabold text-navy mb-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">Oops!</h1>
                    <h4 class="fw-bold text-secondary mb-3">{{title}}</h4>
                    <p class="text-muted mb-4 fs-6">{{message}}</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/" class="btn btn-primary px-4 py-2 text-uppercase tracking-wider rounded-2 shadow-sm">
                            <i class="bi bi-house-door-fill me-2"></i>Go to Home
                        </a>
                        <a href="/contact" class="btn btn-outline-secondary px-4 py-2 text-uppercase tracking-wider rounded-2">
                            <i class="bi bi-envelope-fill me-2"></i>Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
