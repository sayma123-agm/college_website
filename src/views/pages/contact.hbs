<!-- Form submission AJAX script -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contact-inquiry-form');
        const alertBox = document.getElementById('contact-alert');

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const name = document.getElementById('contact-name').value;
                const email = document.getElementById('contact-email').value;
                
                // Fire simulated POST request
                fetch('/api/inquiry', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, phone: '0000000000', course: 'General Inquiry', message: 'Subject: ' + document.getElementById('contact-subject').value })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alertBox.innerText = `Thank you, ${name}! Your feedback message has been delivered successfully.`;
                        alertBox.classList.remove('d-none');
                        form.reset();
                        window.scrollTo({ top: alertBox.offsetTop - 120, behavior: 'smooth' });
                    }
                })
                .catch(err => console.error(err));
            });
        }
    });
</script>
