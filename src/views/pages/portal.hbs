                            <div class="fs-4 text-warning"><i class="bi bi-megaphone-fill"></i></div>
                            <div>
                                <h6 class="fw-bold text-navy m-0" style="font-size: 13px;">New HOD Broadcast Notice:</h6>
                                <p class="text-muted small m-0" id="announcement-broadcast-text">Please submit your VTU elective registration sheets by Friday.</p>
