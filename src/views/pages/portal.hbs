                            <div style="height: 180px; position: relative;">
                                <canvas id="principalChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Parent Panel Widgets -->
                    <div class="space-y-4 d-none" id="panel-parent-widgets">
