        <div>
            <h5 class="fw-extrabold text-navy m-0" style="font-family: 'Plus Jakarta Sans', sans-serif;">AGMRCET Digital Campus</h5>
            <p class="text-muted small m-0" style="font-size: 10px;">Managed by SDM Jainmatt Trust, Varur</p>
        </div>
    </div>
    <a href="/" class="btn btn-outline-secondary btn-sm rounded-2 d-flex align-items-center gap-1.5 fw-semibold" style="font-size: 11px;">
        <i class="bi bi-house-door"></i> Back to Website
