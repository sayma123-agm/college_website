                                    <label class="form-label small text-muted mb-1">Broadcast message to students:</label>
                                    <textarea class="form-control form-control-sm shadow-none" id="broadcast-message-input" rows="3" placeholder="Type announcement here..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning btn-sm w-100 fw-bold text-uppercase py-2 tracking-wider">Publish Notice <i class="bi bi-send ms-1"></i></button>
                            </form>
                            <div id="broadcast-success-alert" class="alert alert-success d-none mt-2 small py-1.5 px-3 text-center" role="alert">Notice Published!</div>
                        </div>
                    </div>

                    <!-- Principal Panel Widgets -->
                    <div class="space-y-4 d-none" id="panel-principal-widgets">
                        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                            <h5 class="fw-bold text-navy mb-3"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Enrollment Summary</h5>
                            <div class="row g-2 text-center text-navy font-bold">
                                <div class="col-6 bg-light p-3 rounded">
                                    <span class="text-muted small d-block" style="font-size: 10px;">UG Students</span>
                                    <h4 class="m-0 fw-bold">1,240</h4>
