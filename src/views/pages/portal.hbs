                            <h4 class="fw-bold text-navy m-0" id="erp-welcome-name">Welcome Back</h4>
                            <p class="text-muted small m-0">System ID: <span id="erp-display-usn" class="fw-semibold"></span> | Status: Authorized Access</p>
                        </div>
                        <button id="erp-logout-btn" class="btn btn-outline-danger btn-sm rounded-2 text-uppercase tracking-wider fw-bold">
                            Logout <i class="bi bi-box-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- HOD Announcement Broadcast Banner -->
            <div class="row g-4 mb-4 d-none" id="erp-announcement-banner">
