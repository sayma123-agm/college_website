                </div>

                <div class="row g-4">
                    <!-- Card 1: Academic Wings -->
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-white hover-translate transition-all" style="border-top: 5px solid var(--primary-color) !important; box-shadow: 0 10px 25px rgba(15, 43, 92, 0.04) !important;">
                            <div class="d-inline-flex align-items-center justify-content-center text-white rounded-4 mb-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;">
                                <i class="bi bi-book-half fs-4"></i>
                            </div>
                            <h5 class="fw-extrabold text-navy mb-2" style="font-family: 'Plus Jakarta Sans', sans-serif;">Academic Wings</h5>
                            <p class="text-muted small mb-4">Gateways for student grade tracking, faculty curriculum boards, and HOD message boards.</p>
                            
                             <div class="d-flex flex-column gap-2 mt-auto">
                                <a href="/portal/student" data-role="student" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-mortarboard-fill text-primary me-2"></i>Student Portal</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                                <a href="/portal/faculty" data-role="faculty" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-person-badge-fill text-primary me-2"></i>Faculty Portal</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                                <a href="/portal/hod" data-role="hod" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-award-fill text-primary me-2"></i>HOD Login</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2: Office & Finance -->
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-white hover-translate transition-all" style="border-top: 5px solid var(--success-color) !important; box-shadow: 0 10px 25px rgba(15, 43, 92, 0.04) !important;">
                            <div class="d-inline-flex align-items-center justify-content-center text-white rounded-4 mb-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--success-color), #047857) !important;">
                                <i class="bi bi-wallet2 fs-4"></i>
                            </div>
                            <h5 class="fw-extrabold text-navy mb-2" style="font-family: 'Plus Jakarta Sans', sans-serif;">Office & Finance</h5>
                            <p class="text-muted small mb-4">Gateways for physical registrar records, challans, scholarships, and term fee clearance.</p>
                            
                            <div class="d-flex flex-column gap-2 mt-auto">
                                <a href="/portal/office" data-role="office" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-building-fill text-success me-2"></i>Office Section</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                                <a href="/portal/fee" data-role="fee" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-credit-card-fill text-success me-2"></i>Fee Section Login</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Executive & Alerts -->
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-white hover-translate transition-all" style="border-top: 5px solid var(--accent-color) !important; box-shadow: 0 10px 25px rgba(15, 43, 92, 0.04) !important;">
                            <div class="d-inline-flex align-items-center justify-content-center text-white rounded-4 mb-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--accent-color), #b45309) !important;">
                                <i class="bi bi-shield-lock fs-4"></i>
                            </div>
                            <h5 class="fw-extrabold text-navy mb-2" style="font-family: 'Plus Jakarta Sans', sans-serif;">Executive & Alerts</h5>
                            <p class="text-muted small mb-4">Access for Principal supervision metrics, Admin console, and Broadcast configurations.</p>
                            
                            <div class="d-flex flex-column gap-2 mt-auto">
                                <a href="/portal/principal" data-role="principal" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-person-workspace text-dark me-2"></i>Principal Portal</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                                <a href="/portal/admin" data-role="admin" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-gear-fill text-dark me-2"></i>Admin Section</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                                <a href="/portal/broadcast" data-role="broadcast" class="gateway-select-btn btn btn-light border text-start py-2.5 px-3 rounded-3 d-flex align-items-center justify-content-between transition-all">
                                    <span class="fw-bold small text-navy"><i class="bi bi-broadcast text-indigo me-2"></i>Broadcast Desk</span>
                                    <i class="bi bi-chevron-right small text-muted"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Authorization Console Form (4 Cols) -->
            <div class="col-lg-4" data-aos="fade-left">
