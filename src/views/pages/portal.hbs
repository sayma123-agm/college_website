                    <!-- Ribbon Accent Header -->
                    <div class="position-absolute top-0 start-0 w-100" style="height: 5px; background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));"></div>
                    
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-primary text-uppercase px-2.5 py-1" id="portal-selected-badge" style="font-size: 10px;">Student</span>
                            <span class="text-success small d-flex align-items-center gap-1" style="font-size: 10px;">
                                <span class="spinner-grow spinner-grow-sm text-success" role="status" style="width: 6px; height: 6px;"></span>
                                SSL Secure
                            </span>
                        </div>
                        <h4 class="fw-extrabold text-navy mb-2" id="portal-info-title" style="font-family: 'Plus Jakarta Sans', sans-serif;">Student Portal ERP</h4>
                        <p class="text-muted small mb-4 leading-relaxed" id="portal-info-desc">Access your semester grade records, track attendance in real-time, view current CGPA progression, download syllabus guidelines, and access academic calendars.</p>
                        
                        <div id="login-error-alert" class="alert alert-danger d-none mb-3 small" role="alert"></div>

                        <form id="erp-login-form">
                            <div class="mb-3">
                                <label for="erp-usn" id="username-label" class="form-label small fw-bold text-navy mb-1">University Seat Number (USN)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-vcard text-muted"></i></span>
                                    <input type="text" class="form-control shadow-none rounded-end-2 text-uppercase border-start-0 bg-light" id="erp-usn" placeholder="2AG22CS001" required>
                                </div>
                                <div class="form-text mt-2 text-navy-50" style="font-size: 10px; background-color: var(--primary-light); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(15, 43, 92, 0.08);">
                                    <span id="hint-text">For demo, use USN: <strong>2AG22CS001</strong></span>
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label for="erp-password" class="form-label small fw-bold text-navy m-0">Password</label>
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal" class="small text-primary fw-bold text-decoration-none" style="font-size: 11px;">Forgot Password?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                    <input type="password" class="form-control shadow-none rounded-end-2 border-start-0 bg-light" id="erp-password" placeholder="••••••••" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-3 text-uppercase tracking-wider fw-bold small rounded-2 shadow-sm hover-scale" style="background: linear-gradient(135deg, var(--secondary-color), var(--primary-color)) !important;">
                                Authenticate <i class="bi bi-box-arrow-in-right ms-1"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!-- Dashboard Stage (Hidden by default, shown via JS) -->
        <div class="d-none" id="erp-dashboard-section">
            <div class="row g-4 mb-4">
                <div class="col-12">
                    <div class="glassmorphism p-4 rounded-4 border border-white-50 shadow-sm d-flex justify-content-between align-items-center flex-wrap gap-3 bg-white">
