                                <input type="range" class="form-range shadow-none" min="15" max="40" value="35" id="pred-slider-ia">
                            </div>
                            <div class="mb-3">
                                <label for="pred-slider-cgpa" class="form-label small text-muted d-flex justify-content-between m-0 mb-1">
                                    <span>Target Semester GPA:</span>
                                    <span class="fw-bold text-navy"><span id="pred-val-cgpa">8.5</span> / 10</span>
                                </label>
                                <input type="range" class="form-range shadow-none" min="6.0" max="10.0" step="0.1" value="8.5" id="pred-slider-cgpa">
                            </div>
                            <div class="p-2.5 bg-primary-light rounded border border-primary-subtle text-center">
                                <span class="d-block text-muted small" style="font-size: 10px;">Required VTU Exam Score:</span>
                                <h5 class="m-0 fw-extrabold text-primary"><span id="pred-val-required">78</span> / 100</h5>
