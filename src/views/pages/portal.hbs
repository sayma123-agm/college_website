<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 glassmorphism shadow-2xl">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-navy text-uppercase tracking-wider" id="forgotPasswordModalLabel">Reset Passcode</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="forgot-password-form">
                    <div class="mb-3">
                        <label for="reset-username" class="form-label small fw-bold text-navy mb-1">Enter USN / ID Code</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-vcard text-muted"></i></span>
                            <input type="text" class="form-control shadow-none rounded-end-2 text-uppercase border-start-0 bg-light" id="reset-username" placeholder="e.g. AGM-FAC-101" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="reset-email" class="form-label small fw-bold text-navy mb-1">Registered Recovery Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input type="email" class="form-control shadow-none rounded-end-2 border-start-0 bg-light" id="reset-email" placeholder="name@college.ac.in" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2.5 text-uppercase tracking-wider fw-bold small rounded-2 mt-2" style="background: linear-gradient(135deg, var(--secondary-color), var(--primary-color)) !important;">
                        Send Recovery Link <i class="bi bi-send ms-1"></i>
                    </button>
                </form>
                <div id="reset-success-alert" class="alert alert-success d-none mt-3 small py-2 px-3 text-center" role="alert">
                    Reset link has been dispatched to your registered email!
                </div>
            </div>
        </div>
    </div>
