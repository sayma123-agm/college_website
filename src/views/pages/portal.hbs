                        </div>
                        <button type="button" class="btn-close shadow-none btn-sm" onclick="document.getElementById('erp-announcement-banner').classList.add('d-none');"></button>
                    </div>
                </div>
            </div>

            <!-- Dynamic Dashboard Panels -->
            <div class="row g-4">
                <!-- Col 1: Gauges & Metrics -->
