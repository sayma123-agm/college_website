<!-- Auto-Show Modal Script (ONLY on Home Page '/', ONLY ONCE per session) -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index';
        const alreadyShown = sessionStorage.getItem('admissionModalShown');
        
        if (isHomePage && !alreadyShown) {
            setTimeout(function () {
                var admissionModalEl = document.getElementById('admissionBannerModal');
                if (admissionModalEl && typeof bootstrap !== 'undefined') {
                    var modalObj = new bootstrap.Modal(admissionModalEl);
                    modalObj.show();
                    sessionStorage.setItem('admissionModalShown', 'true');
                }
            }, 900);
        }
    });
</script>
