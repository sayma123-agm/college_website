<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <meta name="description" content="{{description}}">
    
    <!-- SEO Meta Tags -->
    <link rel="canonical" href="https://www.agmrcet.ac.in{{req.originalUrl}}">
    <meta property="og:title" content="{{title}}">
    <meta property="og:description" content="{{description}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.agmrcet.ac.in{{req.originalUrl}}">
    <meta property="og:image" content="https://www.agmrcet.ac.in/images/og-campus.jpg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{title}}">
    <meta name="twitter:description" content="{{description}}">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- JSON-LD Structured Data Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollegeOrUniversity",
      "name": "AGM Rural College of Engineering and Technology (AGMRCET)",
      "alternateName": "AGMRCET",
      "url": "https://www.agmrcet.ac.in",
      "logo": "https://www.agmrcet.ac.in/images/logo.png",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Navagraha Teertha, NH-4 Road, Varur",
        "addressLocality": "Hubballi",
        "addressRegion": "Karnataka",
        "postalCode": "581207",
        "addressCountry": "IN"
      },
      "telephone": "+91-94810-87999",
      "email": "info@agmrcet.ac.in",
      "sameAs": [
        "https://www.facebook.com/agmrcet",
        "https://www.instagram.com/agmrcet",
        "https://www.linkedin.com/school/agmrcet"
      ]
    }
    </script>
    
    <!-- CDNs Styles -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
    
    <!-- Tailwind CSS (with prefix or utility support) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: {
                preflight: false, // Turn off preflight reset to prevent conflicts with Bootstrap
            }
        }
    </script>
    
    <!-- Custom Style -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Theme Flash Protection Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
            }
        })();
    </script>
</head>
<body>
    <!-- Skip to Main Content Link for Keyboard Navigation (WCAG 2.2) -->
    <a href="#main-content" class="visually-hidden-focusable bg-primary text-white p-3 position-absolute start-0 z-3 m-2 rounded-2">Skip to main content</a>



    <!-- Scroll Progress Indicator -->
    <div id="scroll-progress"></div>

    <!-- Page Loader Animation -->
    <div id="loader-wrapper">
        <div class="loader-content text-center">
            <img src="https://www.agmrcet.ac.in/images/logo.png" alt="AGMRCET Logo" class="mb-3 animate-pulse" style="width: 80px; height: 80px; object-fit: contain;">
            <h5 class="fw-bold tracking-wide text-uppercase" style="color: var(--primary-color);">AGMRCET</h5>
            <p class="text-muted small">Loading Excellence...</p>
        </div>
    </div>

    <!-- Navbar Partial -->
    {{#unless activePortal}}
    {{> navbar}}
    <!-- Scroll Progress Indicator -->
    <div id="scroll-progress"></div>
    {{/unless}}

    <!-- Main Content -->
    <main id="main-content">
        {{{body}}}
    </main>

    <!-- Footer Partial -->
    {{#unless activePortal}}
    {{> footer}}
    {{/unless}}

    <!-- CDNs Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>
    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.19/bundled/lenis.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Global V2 AI Campus Assistant Chatbot -->
    <div id="campus-chatbot-widget" class="position-fixed bottom-4 end-4 z-1000">
        <!-- Chat Float Trigger Button -->
        <button id="chatbot-toggle-btn" class="btn btn-primary rounded-circle p-0 shadow-lg d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; border: 2px solid rgba(255, 255, 255, 0.2); cursor: pointer;">
            <i class="bi bi-chat-dots-fill fs-4 m-0" id="chat-icon-opened"></i>
            <i class="bi bi-x-lg fs-5 m-0 d-none" id="chat-icon-closed"></i>
        </button>

        <!-- Chat Panel -->
        <div id="chatbot-panel" class="glassmorphism rounded-4 shadow-2xl border border-white-50 overflow-hidden d-none bg-white" style="width: 340px; height: 440px; position: absolute; bottom: 70px; right: 0;">
            <!-- Header -->
            <div class="bg-primary text-white p-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <div class="bg-white rounded-circle p-1 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="bi bi-robot text-primary fs-6"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold m-0" style="font-size: 13px;">AGM Campus Guide</h6>
                        <span class="small opacity-75 d-flex align-items-center gap-1" style="font-size: 10px;">
                            <span class="spinner-grow spinner-grow-sm text-success" role="status" style="width: 6px; height: 6px;"></span>
                            AI Assistant Online
                        </span>
                    </div>
                </div>
                <button type="button" class="btn btn-link text-white p-0 border-0 shadow-none" id="chatbot-close-btn" style="text-decoration: none; cursor: pointer;"><i class="bi bi-x-lg fs-6"></i></button>
            </div>

            <!-- Messages Area -->
            <div id="chatbot-messages" class="p-3 overflow-y-auto" style="height: 310px; background-color: var(--bg-light-slate);">
                <!-- Bot Welcome -->
                <div class="d-flex align-items-start gap-2 mb-3">
                    <div class="bg-primary text-white rounded-circle p-1 d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; font-size: 10px;">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div class="bg-white rounded-3 p-2 border shadow-xs" style="max-width: 240px;">
                        <p class="small m-0 text-navy" style="font-size: 11px;">Hello! I am your AGMRCET Campus Guide. How can I assist you today?</p>
                    </div>
                </div>

                <!-- Quick actions buttons -->
                <div class="quick-options-container d-flex flex-wrap gap-1.5 mb-3 ms-4">
                    <button class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 text-navy fw-semibold quick-chat-option" style="font-size: 10px; cursor: pointer;" data-query="Admissions Info">Admissions Info</button>
                    <button class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 text-navy fw-semibold quick-chat-option" style="font-size: 10px; cursor: pointer;" data-query="Engineering Courses">Engineering Courses</button>
                    <button class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 text-navy fw-semibold quick-chat-option" style="font-size: 10px; cursor: pointer;" data-query="Hostel Facilities">Hostel Facilities</button>
                    <button class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 text-navy fw-semibold quick-chat-option" style="font-size: 10px; cursor: pointer;" data-query="Training & Placements">Training & Placements</button>
                    <button class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 text-navy fw-semibold quick-chat-option" style="font-size: 10px; cursor: pointer;" data-query="Go to ERP Portal">Go to ERP Portal</button>
                </div>
            </div>

            <!-- Footer Input -->
            <form id="chatbot-input-form" class="p-2 border-top bg-white d-flex gap-2">
                <input type="text" id="chatbot-input" class="form-control form-control-sm border shadow-none px-3 rounded-pill small" style="font-size: 11px;" placeholder="Type a message..." required>
                <button type="submit" class="btn btn-primary btn-sm rounded-circle d-flex align-items-center justify-content-center p-0 border-0" style="width: 32px; height: 32px; cursor: pointer;"><i class="bi bi-send-fill" style="font-size: 11px;"></i></button>
            </form>
        </div>
    </div>

    <!-- Custom Global JS -->
    <script src="/js/search.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
